{
  "name": "@gekiyasu/schema",
  "version": "0.1.0",
  "private": true,
  "description": "Shared domain types for gekiyasuLLM (Evidence, Offering, RoutePlan, …)",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
