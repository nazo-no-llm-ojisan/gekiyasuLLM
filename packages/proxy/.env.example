# Copy to .env locally if you want (never commit real keys).
# Or export in your shell.

# GEKIYASU_HOST=127.0.0.1
# GEKIYASU_PORT=16191
# GEKIYASU_UPSTREAM_BASE_URL=https://api.openai.com/v1
# Host of UPSTREAM_BASE_URL is always allowed; add more hosts (feed-driven) here:
# GEKIYASU_UPSTREAM_ALLOWLIST=api.openai.com,openrouter.ai
# Require clients to send X-Gekiyasu-Token: <value> on /v1/* (health stays open):
# GEKIYASU_PROXY_TOKEN=change-me
# GEKIYASU_MAX_BODY_BYTES=20971520
# GEKIYASU_UPSTREAM_TIMEOUT_MS=120000
# T-047: comma-separated exact-match origin allowlist for browser CORS.
# Empty (default) means CORS is OFF. Set only when browser access is intended.
# GEKIYASU_CORS_ALLOWLIST=http://localhost:3000
OPENAI_API_KEY=
